# ── Postgres ─────────────────────────────────────────────────────
POSTGRES_USER=seraph
POSTGRES_PASSWORD=seraph_dev
POSTGRES_DB=seraph
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── RabbitMQ ──────────────────────────────────────────────────────
RABBITMQ_URL=amqp://seraph:seraph_dev@localhost:5672/

# ── Auth Service ──────────────────────────────────────────────────
AUTH_PORT=8081
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Google OAuth 2.0 (create credentials at https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8081/auth/google/callback
# Generate with: openssl rand -hex 32
OAUTH_STATE_SECRET=change-me-generate-a-32-byte-hex-secret

# ── Accounts Service ──────────────────────────────────────────────
ACCOUNTS_PORT=8082
LEDGER_SERVICE_URL=http://localhost:8083

# ── Ledger Service ────────────────────────────────────────────────
LEDGER_PORT=8083

# ── Payments Service ──────────────────────────────────────────────
PAYMENTS_PORT=8084
ACCOUNTS_SERVICE_URL=http://localhost:8082

# ── API Gateway ───────────────────────────────────────────────────
GATEWAY_PORT=8080
AUTH_SERVICE_URL=http://auth:8081
ACCOUNTS_SERVICE_URL=http://accounts:8082
LEDGER_SERVICE_URL=http://ledger:8083
PAYMENTS_SERVICE_URL=http://payments:8084

# ── Optional: Blockchain / Settlement ─────────────────────────────
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
SETTLEMENT_WALLET_KEY=your_private_key_here
